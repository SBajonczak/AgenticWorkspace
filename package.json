{
  "name": "agentic-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ci": "npm ci && npm run build",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "npm run prisma:migrate:deploy && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "projects:backfill": "tsx scripts/backfill-projects.ts",
    "todos:dedupe": "tsx scripts/dedupe-meeting-todos.ts",
    "todos:dedupe:apply": "tsx scripts/dedupe-meeting-todos.ts --apply",
    "prisma:studio": "prisma studio",
    "worker": "tsx src/worker/index.ts",
    "worker:once": "prisma migrate deploy && tsx src/worker/run-once.ts",
    "worker:dev": "tsx watch src/worker/index.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@azure/identity": "^4.13.0",
    "@base-ui/react": "^1.3.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^5.8.0",
    "@types/node-cron": "^3.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^10.18.0",
    "isomorphic-fetch": "^3.0.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^4.26.0",
    "prisma": "^5.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nock": "^13.5.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
