# Database
DATABASE_URL="file:./dev.db"
# Optional database provider hint for runtime metadata and future adapter wiring.
# Current focus: sqlite. Later values can be: turso, mssql
DATABASE_PROVIDER="sqlite"

# Microsoft Entra ID (Azure AD)
# Required for both Microsoft Graph API (meeting data) and NextAuth SSO login
AZURE_TENANT_ID="your-tenant-id"
AZURE_CLIENT_ID="your-client-id"
AZURE_CLIENT_SECRET="your-client-secret"   # Required for NextAuth web login

# NextAuth.js
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"        # Change to your production URL

# OpenAI (choose one: standard OpenAI OR Azure OpenAI)
# Option A: Standard OpenAI (default model: gpt-4o-mini – cost-optimized)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-5.1"                 # Override default model

# Option B: Azure OpenAI (from Terraform output or Azure Portal)
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_ENDPOINT=""                 # e.g. https://oai-agentic-workspace.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"

# Meeting Minutes – output languages (comma-separated ISO codes)
OUTPUT_LANGUAGES="de,en"

# Jira (optional – omit to skip Jira sync)
JIRA_HOST="https://your-domain.atlassian.net"
JIRA_EMAIL="your-email@example.com"
JIRA_API_TOKEN="your-jira-api-token"
JIRA_PROJECT_KEY="YOUR-PROJECT"

# Background Worker
WORKER_INTERVAL_MINUTES=30   # How often the worker polls for new meetings (minutes)
# The UPN (email) or Azure AD object ID of the user whose meetings the worker should process.
# Required for background worker (app permissions use /users/{id}/ not /me/).
GRAPH_TARGET_USER_ID=user@yourcompany.com

# Agent Configuration
DRY_RUN="true"               # Set to "false" in production to enable LLM + Jira calls
